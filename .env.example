# --- MVP fallback ---
# Comma-separated list of emails that get instant access (no Supabase needed).
# Falls back to /config/approvedEmails.json if not set.
APPROVED_EMAILS=demo@freedomhustle.com,buyer@example.com

# --- Optional: Supabase (recommended once you have real buyers) ---
# Create a `purchases` table with columns: id, email (text), guide_slug (text),
# access_granted (boolean), created_at (timestamptz default now()).
# Then add an RLS policy or use the service role key server-side only.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: where to send users who don't have access yet ---
NEXT_PUBLIC_CHECKOUT_URL=https://your-checkout.lemonsqueezy.com/buy/bangkok-guide

# --- Optional: Google Places API (for <PlaceCard /> blocks) ---
# Without this key, PlaceCard renders a basic link fallback.
# With it, pasting any Google Maps URL auto-fills name, address, rating, and photo.
#
# Setup:
#   1. Create a Google Cloud project: https://console.cloud.google.com
#   2. Enable "Places API (New)"
#   3. Create an API key, restrict to your domain in production
#   4. Paste it here — kept server-side only
GOOGLE_PLACES_API_KEY=
